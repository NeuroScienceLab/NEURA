{
  "tool_name": "python_stats",
  "description": "Python统计分析工具",
  "version": "2.0",
  "operations": {
    "ttest": {
      "description": "t检验 (独立样本/配对样本)",
      "references": ["Cohen (1988) Statistical Power Analysis for the Behavioral Sciences, 2nd ed."],
      "required_input_fields": ["data"],
      "optional_input_fields": ["test_type", "equal_var", "alternative"],
      "expected_output_fields": ["t_statistic", "p_value", "effect_size", "confidence_interval", "degrees_of_freedom"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "p值在[0,1]范围"},
        {"check": "sample_size_adequate", "params": {"min_per_group": 5}, "description": "每组样本量>=5"},
        {"check": "normality_test", "description": "Shapiro-Wilk正态性检验 (建议手动检查)"},
        {"check": "equal_variance_test", "description": "Levene方差齐性检验 (建议手动检查)"}
      ],
      "reference_parameters": {
        "test_types": ["independent", "paired"],
        "effect_size_note": "Cohen's d: 0.2=小, 0.5=中, 0.8=大 (Cohen, 1988)",
        "alternative_options": ["two-sided", "less", "greater"],
        "confidence_level": 0.95
      },
      "acceptance_criteria": {
        "description": "t检验输出合格判定标准",
        "pass_conditions": [
          {"field": "p_value", "range": [0, 1], "severity": "error"},
          {"field": "n_per_group", "range": [5, 9999999], "severity": "error"},
          {"field": "effect_size", "check": "reported", "severity": "warning", "note": "应报告Cohen's d和CI"}
        ],
        "fail_conditions": [
          {"field": "p_value", "range_outside": [0, 1], "severity": "error"},
          {"field": "n_per_group", "threshold": 3, "operator": "<", "severity": "error", "message": "每组n<3，结果不可靠"}
        ],
        "warning_conditions": [
          {"field": "n_per_group", "threshold": 5, "operator": "<", "severity": "warning", "message": "每组n<5，统计效能不足"},
          {"field": "effect_size", "check": "not_reported", "severity": "warning", "message": "未报告效应量"}
        ]
      }
    },
    "anova": {
      "description": "方差分析",
      "references": ["Tabachnick & Fidell (2013) Using Multivariate Statistics, 6th ed."],
      "required_input_fields": ["data", "groups"],
      "optional_input_fields": ["anova_type", "covariates", "repeated_measures_factor"],
      "expected_output_fields": ["f_statistic", "p_value", "eta_squared", "post_hoc_results"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "p值在[0,1]范围"},
        {"check": "sample_size_adequate", "params": {"min_per_group": 5}, "description": "每组样本量>=5"},
        {"check": "value_range", "field": "eta_squared", "params": {"min": 0, "max": 1}, "description": "η²在[0,1]范围"},
        {"check": "homogeneity_of_variance", "description": "Levene方差齐性检验 (建议手动检查)"},
        {"check": "sphericity_test", "description": "Mauchly球形检验 (重复测量时, 建议手动检查)"}
      ],
      "reference_parameters": {
        "anova_types": ["one_way", "two_way", "repeated_measures", "mixed"],
        "post_hoc_options": ["tukey", "bonferroni", "scheffe", "games_howell"],
        "effect_size_note": "η²: 0.01=小, 0.06=中, 0.14=大",
        "post_hoc_note": "方差齐时用Tukey，不齐时用Games-Howell"
      },
      "acceptance_criteria": {
        "description": "方差分析输出合格判定标准",
        "pass_conditions": [
          {"field": "p_value", "range": [0, 1], "severity": "error"},
          {"field": "eta_squared", "range": [0, 1], "severity": "error"},
          {"field": "n_per_group", "range": [5, 9999999], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "p_value", "range_outside": [0, 1], "severity": "error"},
          {"field": "eta_squared", "range_outside": [0, 1], "severity": "error"}
        ],
        "warning_conditions": [
          {"check": "post_hoc_missing", "condition": "n_groups > 2", "severity": "warning", "message": "多于2组时未做事后检验"}
        ]
      }
    },
    "correlation": {
      "description": "相关分析",
      "references": ["Bonett & Wright (2000) Sample size requirements for estimating Pearson, Kendall and Spearman correlations, Psychometrika 65:23-28"],
      "required_input_fields": ["data"],
      "optional_input_fields": ["method", "covariates"],
      "expected_output_fields": ["r_value", "p_value", "confidence_interval", "partial_correlation"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "r_value_valid", "params": {"min": -1, "max": 1}, "description": "相关系数在[-1,1]范围"},
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "p值在[0,1]范围"},
        {"check": "sample_size_adequate", "params": {"min_n": 10}, "description": "样本量>=10"}
      ],
      "reference_parameters": {
        "method_options": ["pearson", "spearman", "kendall"],
        "pearson_note": "要求双变量正态分布",
        "spearman_note": "非参数，适用于非正态或有序数据",
        "partial_note": "偏相关控制混淆变量后的相关"
      },
      "acceptance_criteria": {
        "description": "相关分析输出合格判定标准",
        "pass_conditions": [
          {"field": "r_value", "range": [-1, 1], "severity": "error"},
          {"field": "p_value", "range": [0, 1], "severity": "error"},
          {"field": "n", "range": [10, 9999999], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "r_value", "range_outside": [-1, 1], "severity": "error"},
          {"field": "p_value", "range_outside": [0, 1], "severity": "error"}
        ],
        "warning_conditions": []
      }
    },
    "regression": {
      "description": "回归分析",
      "references": ["Fox (2015) Applied Regression Analysis and Generalized Linear Models, 3rd ed."],
      "required_input_fields": ["data"],
      "optional_input_fields": ["model_type", "covariates", "interaction_terms"],
      "expected_output_fields": ["coefficients", "r_squared", "adjusted_r_squared", "p_values", "vif", "residual_normality"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "r_squared_valid", "params": {"min": 0, "max": 1}, "description": "R²在[0,1]范围"},
        {"check": "value_range", "field": "vif_max", "params": {"max": 10}, "description": "VIF<10 (无严重多重共线性)"},
        {"check": "residual_normality", "description": "残差正态性检验 (建议手动检查)"},
        {"check": "value_range", "field": "cooks_distance_max", "params": {"max": 1.0}, "description": "Cook's距离<1 (无强影响点)"}
      ],
      "reference_parameters": {
        "model_types": ["linear", "logistic", "polynomial"],
        "vif_note": "VIF>10提示严重多重共线性 (Kutner MH, Nachtsheim CJ, Neter J, Li W (2004) Applied Linear Statistical Models, 5th ed., McGraw-Hill)",
        "cooks_distance_note": "Cook's D>1提示强影响点",
        "adjusted_r_squared_note": "调整R²惩罚过多预测变量"
      },
      "acceptance_criteria": {
        "description": "回归分析输出合格判定标准",
        "pass_conditions": [
          {"field": "r_squared", "range": [0, 1], "severity": "error"},
          {"field": "vif_max", "range": [0, 10], "severity": "error"},
          {"field": "cooks_distance_max", "range": [0, 1], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "vif_max", "threshold": 10, "operator": ">", "severity": "error", "message": "VIF>10，严重多重共线性"}
        ],
        "warning_conditions": [
          {"field": "vif_max", "threshold": 5, "operator": ">", "severity": "warning", "message": "VIF 5-10，存在多重共线性"}
        ]
      }
    },
    "nonparametric": {
      "description": "非参数检验",
      "references": ["Hollander et al. (2013) Nonparametric Statistical Methods, 3rd ed."],
      "required_input_fields": ["data"],
      "optional_input_fields": ["test_type", "alternative"],
      "expected_output_fields": ["statistic", "p_value", "effect_size"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "p值在[0,1]范围"},
        {"check": "sample_size_adequate", "params": {"min_per_group": 3}, "description": "每组样本量>=3"}
      ],
      "reference_parameters": {
        "test_types": {
          "two_independent": "Mann-Whitney U",
          "two_paired": "Wilcoxon signed-rank",
          "k_independent": "Kruskal-Wallis H",
          "k_paired": "Friedman"
        },
        "effect_size_note": "r = Z/√N (Mann-Whitney/Wilcoxon)"
      },
      "acceptance_criteria": {
        "description": "非参数检验输出合格判定标准",
        "pass_conditions": [
          {"field": "p_value", "range": [0, 1], "severity": "error"},
          {"field": "n_per_group", "range": [3, 9999999], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "p_value", "range_outside": [0, 1], "severity": "error"}
        ],
        "warning_conditions": []
      }
    },
    "multiple_comparison": {
      "description": "多重比较校正",
      "references": [
        "Benjamini & Hochberg (1995) Controlling the false discovery rate, JRSS-B 57:289-300",
        "Nichols & Hayasaka (2003) Controlling the familywise error rate in functional neuroimaging, Statistical Methods in Medical Research 12:419-446"
      ],
      "required_input_fields": ["p_values"],
      "optional_input_fields": ["method", "alpha"],
      "expected_output_fields": ["corrected_p_values", "rejected_hypotheses", "n_significant"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "校正后p值在[0,1]范围"}
      ],
      "reference_parameters": {
        "method_options": ["fdr_bh", "fdr_by", "bonferroni", "holm", "sidak", "fwe_permutation"],
        "alpha": 0.05,
        "fdr_note": "FDR (Benjamini-Hochberg) 控制假发现率，比Bonferroni更宽松",
        "fwe_note": "FWE (Bonferroni/permutation) 控制族错误率，更保守"
      },
      "acceptance_criteria": {
        "description": "多重比较校正输出合格判定标准",
        "pass_conditions": [
          {"field": "corrected_p", "range": [0, 1], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "corrected_p", "range_outside": [0, 1], "severity": "error"}
        ],
        "warning_conditions": []
      }
    },
    "mixed_effects": {
      "description": "混合效应模型",
      "references": ["Bates et al. (2015) Fitting linear mixed-effects models using lme4, Journal of Statistical Software 67:1-48"],
      "required_input_fields": ["data", "formula"],
      "optional_input_fields": ["random_effects", "reml", "optimizer"],
      "expected_output_fields": ["fixed_effects", "random_effects_variance", "aic", "bic", "log_likelihood"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "p_value_valid", "params": {"min": 0, "max": 1}, "description": "p值在[0,1]范围"},
        {"check": "value_positive", "field": "random_effects_variance", "description": "随机效应方差为正"},
        {"check": "model_convergence", "description": "模型收敛 (建议手动检查)"}
      ],
      "reference_parameters": {
        "reml": true,
        "reml_note": "REML (限制最大似然) 对方差估计无偏",
        "formula_example": "y ~ group * time + (1|subject)",
        "note": "适用于重复测量、嵌套设计、纵向数据"
      },
      "acceptance_criteria": {
        "description": "混合效应模型输出合格判定标准",
        "pass_conditions": [
          {"field": "converged", "expected": true, "severity": "error"},
          {"field": "random_effects_variance", "range": [0, 9999999], "severity": "error", "note": "随机效应方差应为正"},
          {"field": "p_value", "range": [0, 1], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "converged", "expected": false, "severity": "error", "message": "模型未收敛"}
        ],
        "warning_conditions": []
      }
    },
    "read_eddy_qc": {
      "description": "读取eddy QC指标",
      "required_input_fields": ["eddy_output"],
      "expected_output_fields": ["mean_motion", "max_motion"],
      "expected_output_files": [],
      "quality_checks": [
        {"check": "motion_threshold", "params": {"max_mm": 2.0}, "description": "平均运动<2mm"}
      ],
      "acceptance_criteria": {
        "description": "eddy QC读取合格判定标准",
        "pass_conditions": [
          {"field": "mean_motion", "range": [0, 2.0], "severity": "error"}
        ],
        "fail_conditions": [
          {"field": "mean_motion", "threshold": 3.0, "operator": ">", "severity": "error", "action": "exclude_subject"}
        ],
        "warning_conditions": []
      }
    }
  }
}